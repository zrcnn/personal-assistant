# PA 项目搜索服务环境变量配置模板
# 复制此文件为 .env 并填入你的 API 密钥

# ============================================================
# 搜索 API 配置（至少配置一项）
# ============================================================

# --- 选项 1: Google Custom Search（推荐）---
# 创建指南: https://developers.google.com/custom-search/v1/overview
# GOOGLE_SEARCH_API_KEY=your_google_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here

# --- 选项 2: Bing Search API ---
# 创建指南: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# BING_SEARCH_API_KEY=your_bing_api_key_here

# --- 选项 3: Brave Search API ---
# 创建指南: https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# ============================================================
# 可选配置
# ============================================================

# 最大搜索结果数（默认: 5）
# PA_SEARCH_MAX_RESULTS=5

# 搜索超时时间（毫秒，默认: 8000）
# PA_SEARCH_TIMEOUT=8000
