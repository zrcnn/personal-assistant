# PA Backend Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pa
DB_PASSWORD=your_password_here
DB_NAME=personal_assistant

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_change_in_production_min_32_chars

# Server Configuration
PORT=8090

# Admin Username (for /api/admin endpoints)
ADMIN_USERNAME=admin

# Optional: External API Keys (if using additional services)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
