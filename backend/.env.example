# PA Backend Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pa
DB_PASSWORD=your_password_here
DB_NAME=personal_assistant

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_change_in_production_min_32_chars

# Server Configuration
PORT=8090

# Admin Username (for /api/admin endpoints)
ADMIN_USERNAME=admin

# Optional: External API Keys (if using additional services)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ============================================================
# Web Search Configuration (for AI assistant internet access)
# ============================================================
# The AI assistant can search the internet for real-time information.
# Configure at least one search provider to enable this feature.
#
# Option 1: Google Custom Search Engine (recommended)
#   1. Create a Custom Search Engine at https://cse.google.com/cse/
#   2. Get your API key from https://developers.google.com/custom-search/v1/overview
#   3. Set both values below:
# GOOGLE_SEARCH_API_KEY=your_google_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here
#
# Option 2: Bing Search API
#   1. Create a Bing Search resource in Azure Portal
#   2. Get your API key from the resource
# BING_SEARCH_API_KEY=your_bing_api_key_here
#
# If no search API is configured, the AI assistant will respond that
# search is unavailable when the user triggers a search query.
